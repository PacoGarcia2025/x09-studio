# Ambiente — copiar para .env.local (dev) e /opt/x09-studio/.env (VPS)
# Projeto Supabase EXCLUSIVO do X09 Studio.
# Use as API keys ATUAIS (publishable + secret). Não use Legacy anon/service_role JWTs.

# App
NODE_ENV=production
PORT=3001
HOSTNAME=0.0.0.0
NEXT_PUBLIC_APP_URL=https://studio.x09.com.br
NEXT_PUBLIC_VISUAL_MVP_URL=https://studio.x09.com.br
CORS_ALLOWED_ORIGINS=https://studio.x09.com.br,http://localhost:5173

# Paths portáteis (migração de VPS só muda estes valores)
STUDIO_PROJECTS_ROOT=/var/lib/x09-studio/projects
STUDIO_PUBLISH_ROOT=/var/lib/x09-studio/published
STUDIO_PUBLISH_DOMAIN=studio.x09.com.br
STUDIO_DOCKER_NETWORK=x09-studio-preview
STUDIO_PREVIEW_IDLE_MS=1800000

# Supabase — plataforma Studio
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STUDIO_PROJECT.supabase.co

# Chave pública (Publishable Key: sb_publishable_...)
# Nome canônico novo: NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# Alias aceito pelo código: NEXT_PUBLIC_SUPABASE_ANON_KEY (mesmo valor publishable)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Chave secreta backend (Secret Key: sb_secret_...) — NUNCA no browser
# Nome canônico novo: SUPABASE_SECRET_KEY
# Alias aceito: SUPABASE_SERVICE_ROLE_KEY (mesmo valor secret)
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# LLM — modelos ativos (somente no servidor / PM2 — NUNCA VITE_*)
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
MISTRAL_API_KEY=your-mistral-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
TOGETHER_API_KEY=your-together-api-key
XAI_API_KEY=your-xai-api-key

# Visual MVP (Vite) — só Supabase anon + URL do BFF (vazio = proxy /api)
# VITE_API_BASE=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ─── Billing Mercado Pago (Checkout Pro / pacotes de créditos) ───
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=your-mp-webhook-secret
# Somente em testes locais sem assinatura: MP_WEBHOOK_SKIP_VERIFY=1
# Webhook: https://studio.x09.com.br/api/webhooks/mercadopago

# ─── GitHub App (sync de repositório) ───
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=x09-studio
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
# Somente em testes locais: GITHUB_WEBHOOK_SKIP_VERIFY=1
# Callback da App: https://studio.x09.com.br/api/github/callback
# Webhook: https://studio.x09.com.br/api/github/webhook

# ─── Vercel Deploy API ───
VERCEL_TOKEN=your-vercel-token
VERCEL_TEAM_ID=
VERCEL_WEBHOOK_SECRET=your-vercel-webhook-secret
VERCEL_PROJECT_NAME_PREFIX=x09
# Somente em testes locais: VERCEL_WEBHOOK_SKIP_VERIFY=1
# Webhook: https://studio.x09.com.br/api/webhooks/vercel

# E-mail
RESEND_API_KEY=re_...

# Domínios, CDN e storage
CLOUDFLARE_API_TOKEN=your-cloudflare-token
CLOUDFLARE_ZONE_ID=your-zone-id
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=x09-studio

# Observabilidade
SENTRY_DSN=https://...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Bootstrap do primeiro owner (não versionar valores reais)
STUDIO_OWNER_EMAIL=owner@example.com
STUDIO_OWNER_PASSWORD=change-me
